# Copy this to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.

# Supabase project credentials (from: supabase.com/dashboard/project/<id>/settings/api)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Supabase Edge Function secrets ---
# Set these in the Supabase dashboard under: Settings > Edge Functions > Secrets
# Do NOT put these in .env.local — they never touch the browser.
#
# XERO_CLIENT_ID=your-xero-client-id
# XERO_CLIENT_SECRET=your-xero-client-secret
# XERO_REDIRECT_URI=https://your-project.supabase.co/functions/v1/xero-callback
# APP_URL=https://amortix.io
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
